# Django
DJANGO_SECRET_KEY=dev-secret-key-not-for-production-abc123xyz789
DJANGO_DEBUG=True

# SQLite (desenvolvimento local sem MySQL)
DATABASE_NAME=db.sqlite3

# Domínio (Localhost)
